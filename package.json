{
	"name": "@elsikora/nestjs-typeorm-aws-connector",
	"version": "1.3.4-dev.1",
	"description": "NestJS application configuration with AWS Parameter Store and TypeORM",
	"homepage": "https://github.com/ElsiKora/NestJS-AWS-TypeORM-Connector#readme",
	"bugs": {
		"url": "https://github.com/ElsiKora/NestJS-AWS-TypeORM-Connector/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ElsiKora/NestJS-TypeORM-AWS-Connector"
	},
	"license": "MIT",
	"author": "ElsiKora",
	"type": "module",
	"exports": {
		".": {
			"require": "./dist/cjs/index.js",
			"import": "./dist/esm/index.js"
		}
	},
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "npm run prebuild && rollup -c",
		"commit": "cz",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint ./",
		"lint:all": "npm run lint && npm run lint:types",
		"lint:all:fix": "npm run lint:fix && npm run lint:types:fix",
		"lint:fix": "eslint --fix ./",
		"lint:test": "eslint \"{src,apps,libs,test}/**/*.spec.ts\"",
		"lint:types": "tsc --noEmit",
		"lint:types:fix": "tsc --noEmit --skipLibCheck",
		"lint:watch": "npx eslint-watch ./",
		"prepare": "husky",
		"release": "semantic-release"
	},
	"config": {
		"commitizen": {
			"path": "@elsikora/commitizen-plugin-commitlint-ai"
		}
	},
	"dependencies": {
		"@aws-sdk/client-secrets-manager": "^3.1007.0",
		"@elsikora/nestjs-aws-parameter-store-config": "^2.0.2",
		"@nestjs/config": "^4.0.3",
		"@nestjs/schedule": "^6.1.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@elsikora/cladi": "^2.0.2",
		"@elsikora/commitizen-plugin-commitlint-ai": "^2.5.0",
		"@elsikora/eslint-config": "^3.10.0",
		"@elsikora/eslint-plugin-nestjs-typed": "^3.0.1",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/common": "^11.1.16",
		"@nestjs/core": "^11.1.16",
		"@nestjs/schematics": "^11.0.9",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@saithodev/semantic-release-backmerge": "^4.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^25.4.0",
		"commitizen": "^4.3.1",
		"conventional-changelog-conventionalcommits": "^9.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-ng-module-sort": "^1.4.0",
		"eslint-plugin-no-secrets": "^2.3.3",
		"eslint-plugin-typeorm-typescript": "^0.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"rollup": "^4.59.0",
		"rollup-plugin-dts-path-alias": "^0.0.3",
		"rollup-plugin-generate-package-json": "^3.2.0",
		"rxjs": "^7.8.2",
		"semantic-release": "^25.0.3",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@aws-sdk/client-ssm": "^3.535.0",
		"@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
		"typeorm": "^0.3.20"
	},
	"publishConfig": {
		"access": "public"
	}
}
